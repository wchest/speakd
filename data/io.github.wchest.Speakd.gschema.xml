<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="io.github.wchest.Speakd" path="/io/github/wchest/Speakd/">

    <key name="api-key" type="s">
      <default>''</default>
      <summary>Deepgram API key</summary>
    </key>

    <key name="listening-mode" type="s">
      <default>'always-on'</default>
      <choices>
        <choice value='always-on'/>
        <choice value='push-to-talk'/>
        <choice value='toggle'/>
      </choices>
      <summary>Listening mode</summary>
    </key>

    <key name="output-mode" type="s">
      <default>'clipboard'</default>
      <choices>
        <choice value='clipboard'/>
        <choice value='insert'/>
        <choice value='both'/>
      </choices>
      <summary>Output mode</summary>
    </key>

    <key name="vad-threshold" type="d">
      <default>0.05</default>
      <range min="0.01" max="0.5"/>
      <summary>Normalized RMS audio level treated as speech</summary>
    </key>

    <key name="silence-duration" type="i">
      <default>1500</default>
      <range min="500" max="5000"/>
      <summary>Milliseconds of silence before audio streaming pauses (ms)</summary>
    </key>

    <key name="input-device" type="s">
      <default>''</default>
      <summary>Selected input device</summary>
    </key>

    <key name="remote-desktop-restore-token" type="s">
      <default>''</default>
      <summary>RemoteDesktop portal restore token for Type at Cursor</summary>
    </key>

    <key name="clipboard-session-reset" type="i">
      <default>5000</default>
      <range min="1000" max="60000"/>
      <summary>Milliseconds of quiet before the clipboard starts a fresh session</summary>
    </key>

    <!-- Usage Tracking -->
    <key name="usage-minutes-month" type="d">
      <default>0.0</default>
      <summary>Minutes transcribed this month</summary>
    </key>

    <key name="usage-minutes-session" type="d">
      <default>0.0</default>
      <summary>Minutes transcribed this session</summary>
    </key>

    <key name="usage-reset-date" type="s">
      <default>''</default>
      <summary>Date when monthly usage was last reset (YYYY-MM)</summary>
    </key>

    <key name="monthly-limit-minutes" type="d">
      <default>60.0</default>
      <range min="0" max="10000"/>
      <summary>Monthly usage limit in minutes (0 = unlimited)</summary>
    </key>

    <key name="limit-warning-threshold" type="d">
      <default>0.8</default>
      <range min="0.5" max="1.0"/>
      <summary>Show warning when usage reaches this percentage of limit</summary>
    </key>

    <key name="hard-limit-enabled" type="b">
      <default>false</default>
      <summary>Stop transcription when limit is reached</summary>
    </key>

  </schema>
</schemalist>
